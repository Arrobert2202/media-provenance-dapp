{
  "name": "image-traceability-server",
  "version": "1.0.0",
  "description": "Express API backend for the Hybrid DApp Image Traceability PoC",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:verbose": "jest --runInBand --forceExit --verbose",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "server.js"
    ]
  },
  "dependencies": {
    "cors": "2.8.5",
    "ethers": "^6.16.0",
    "express": "4.18.2",
    "multer": "1.4.5-lts.1",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.0.2",
    "supertest": "7.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
